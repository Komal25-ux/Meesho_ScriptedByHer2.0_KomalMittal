# ── SYSTEM CONFIGURATION ──────────────────────────────────
PORT=8000
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
WS_HEARTBEAT_INTERVAL=30

# ── SARVAM AI (ASR & TTS) ─────────────────────────────────
# #to-do: Register on https://dashboard.sarvam.ai/ and obtain an API key
SARVAM_API_KEY=YOUR_SARVAM_API_KEY_HERE

# ── GOOGLE GEMINI ─────────────────────────────────────────
# #to-do: Register on https://aistudio.google.com/ and obtain a Gemini API key
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash

# ── SUPABASE CONFIGURATION ────────────────────────────────
# #to-do: Create a project on https://supabase.com/ and obtain service keys
SUPABASE_URL=YOUR_SUPABASE_URL_HERE
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_KEY_HERE
